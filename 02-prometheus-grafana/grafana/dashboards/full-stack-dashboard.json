{
  "title": "Cross-Day Stack (Day 23)",
  "uid": "day23-cross-day",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {
      "type": "stat", "title": "Day 16 — Cloud Hosts Up",
      "id": 1, "gridPos": {"x": 0, "y": 0, "w": 8, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "count(up{job=~\"node.*\"})", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red",   "value": null},
              {"color": "green", "value": 1}
            ]
          }
        }
      },
      "options": {"colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"}
    },
    {
      "type": "timeseries", "title": "Day 17 — Airflow DAG Duration (P95)",
      "id": 2, "gridPos": {"x": 8, "y": 0, "w": 8, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{
        "expr": "histogram_quantile(0.95, sum by (le) (rate(airflow_dag_run_duration_seconds_bucket[5m])))",
        "legendFormat": "P95 DAG Duration", "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "spanNulls": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 120},
              {"color": "red",   "value": 300}
            ]
          }
        }
      }
    },
    {
      "type": "stat", "title": "Day 18 — Spark App Active",
      "id": 3, "gridPos": {"x": 16, "y": 0, "w": 8, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "count(spark_application_active)", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red",   "value": null},
              {"color": "green", "value": 1}
            ]
          }
        }
      },
      "options": {"colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"}
    },
    {
      "type": "stat", "title": "Day 19 — Qdrant Collections",
      "id": 4, "gridPos": {"x": 0, "y": 8, "w": 8, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "day19_qdrant_collections", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "noValue": "—",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "blue",  "value": null},
              {"color": "green", "value": 1}
            ]
          }
        }
      },
      "options": {"colorMode": "value", "graphMode": "none", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"}
    },
    {
      "type": "timeseries", "title": "Day 20 — llama.cpp Tokens/sec",
      "id": 5, "gridPos": {"x": 8, "y": 8, "w": 8, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{
        "expr": "day20_llamacpp_tokens_per_second",
        "legendFormat": "tokens/s", "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "spanNulls": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 10},
              {"color": "red",   "value": 2}
            ]
          }
        }
      }
    },
    {
      "type": "gauge", "title": "Day 22 — DPO Eval Pass Rate",
      "id": 6, "gridPos": {"x": 16, "y": 8, "w": 8, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "day22_dpo_eval_pass_rate", "refId": "A"}],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red",   "value": null},
              {"color": "yellow","value": 0.5},
              {"color": "green", "value": 0.7}
            ]
          }
        }
      },
      "options": {
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      }
    }
  ]
}
