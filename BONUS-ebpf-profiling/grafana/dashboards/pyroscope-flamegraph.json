{
  "title": "Pyroscope / Flame Graph (Day 23)",
  "uid": "day23-pyroscope",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-15m", "to": "now"},
  "panels": [
    {
      "type": "pyroscope-flamegraph",
      "title": "Flame Graph — CPU Profile",
      "id": 1,
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 16},
      "datasource": {"type": "phlare", "uid": "pyroscope"},
      "options": {
        "pyroscope": {
          "profileTypeId": "process_cpu"
        }
      }
    },
    {
      "type": "row",
      "title": "Profile Stats",
      "id": 2,
      "gridPos": {"x": 0, "y": 16, "w": 24, "h": 1}
    },
    {
      "type": "stat", "title": "CPU Samples (last 15m)",
      "id": 3, "gridPos": {"x": 0, "y": 17, "w": 6, "h": 6},
      "datasource": {"type": "phlare", "uid": "pyroscope"},
      "targets": [{
        "expr": "sum(rate(pyroscope_cpu_samples_total{application=\"day23-app\"}[5m])) * 300",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null}
            ]
          }
        }
      }
    },
    {
      "type": "timeseries", "title": "Wall Time by Function (top 10)",
      "id": 4, "gridPos": {"x": 6, "y": 17, "w": 18, "h": 6},
      "datasource": {"type": "phlare", "uid": "pyroscope"},
      "targets": [
        {
          "expr": "topk(10, sum by (function_name) (rate(pyroscope_cpu_samples_total{application=\"day23-app\"}[5m])))",
          "legendFormat": "{{function_name}}", "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "drawStyle": "bars",
            "lineInterpolation": "stepped",
            "showPoints": "never"
          }
        }
      }
    }
  ]
}
